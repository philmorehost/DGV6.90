# DGV6.90 — /bc-admin/.htaccess
# Clean URLs for vendor admin panel
# Strips .php extension while keeping all functionality intact.

Options -Indexes
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /bc-admin/

    # ── RULE 1: Redirect *.php → clean URL (301) ──────────────────────────────
    # Skip ajax/export handlers — they're called programmatically not via address bar
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteCond %{THE_REQUEST} /bc-admin/([^?#]+)\.php([?#\s]) [NC]
    RewriteCond %{REQUEST_URI} !^/bc-admin/(ajax-|export-|payhub-|index\.php) [NC]
    RewriteRule ^(.+)\.php$ /bc-admin/$1 [L,R=301,QSA,NC]

    # ── RULE 2: Serve clean URL → actual .php file ─────────────────────────────
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^([^.]+)$ $1.php [L,QSA,NC]

</IfModule>
