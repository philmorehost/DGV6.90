# DGV6.90 — Root .htaccess
# Optimized for cPanel / Shared Hosting Compatibility

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. Force HTTPS (skip if already HTTPS or running locally)
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP_HOST} !^localhost [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
    RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [L,R=301]

    # 2. Force non-www (www.example.com → example.com)
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^(.*)$ https://%1/$1 [L,R=301]

    # 3. Block access to sensitive system directories
    RewriteRule ^func/ - [F,L]
    RewriteRule ^logs/ - [F,L]
    RewriteRule ^cron/ - [F,L]
    RewriteRule ^tests/ - [F,L]
</IfModule>

# 4. Security Headers (Safe Subset)
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    # Note: Header unset Server is intentionally omitted for compatibility
</IfModule>

# 5. Disable Directory Browsing
Options -Indexes

# 6. Protect sensitive file types
<FilesMatch "\.(env|ini|log|bak|sh|sql|md)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# 7. GZIP Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/json application/xml
</IfModule>
